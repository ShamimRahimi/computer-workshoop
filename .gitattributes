# Auto detect text files and perform LF normalization
* text=auto

#include <stdio.h>
#include <math.h>


double tool(int x1,int y1,int x2,int y2){
    double tooll;
    tooll=sqrt(pow((y2-y1),2)+pow((x2-x1),2));
    return (double)tooll;
}


double area(int x1,int y1,int x2,int y2,int x3,int y3){
    double areaa;
    areaa=(0.5)*(x1*(y2-y3)+x2*(y3-y1)+x3*(y1-y2));
    return (double)fabs(areaa);
}


double max(double a,double b){
    double maxx=0;
    if(a>=b){
        maxx = a;
}
    if(a<b){
        maxx = b;
    }
    return (double)maxx;
}


int main(){
    int n;
    int x1,x2,x3,x4,y1,y2,y3,y4;
    double nesbat=0,nesbat2=0,nesbat3=0;
    scanf("%d", &n );
    
    while(1){
        nesbat3 = 0;
        for(int i=1; i<=n ;i++){
            scanf("%d%d%d%d%d%d%d%d", &x1 , &y1 , &x2 , &y2 , &x3 , &y3 , &x4 , &y4);

            double areaa=area(x1,y1,x2,y2,x3,y3)+area(x1,y1,x3,y3,x4,y4);
            double tooll=tool(x1,y1,x2,y2)+tool(x3,y3,x2,y2)+tool(x3,y3,x4,y4)+tool(x4,y4,x1,y1);
            printf("%.2f\n%.2f\n", areaa , tooll );


            double nesbat2=areaa/tooll;
            nesbat3=max(nesbat3,nesbat2);
        }
        printf("%.2f", nesbat3);
        break;
}
    return 0;
}
